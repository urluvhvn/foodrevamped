{
	"schemaVersion": 1,
	"id": "nutritionplus",
	"version": "${version}",
	"name": "NutritionPlus",
	"description": "Minecraft's nutrition system REIMAGINED",
	"authors": [
		"hvn"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/nutritionplus/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"hvn.nutritionplus.NutritionPlus"
		],
		"client": [
			"hvn.nutritionplus.client.NutritionPlusClient"
		]
	},
	"mixins": [
		"nutritionplus.mixins.json",
		{
			"config": "nutritionplus.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
